# Software Factory v4 prototype — city configuration template.
#
# Rendered by entrypoint.sh (envsubst) into /workspace/city/city.toml on every
# start. The pack.toml beside it imports the bundled `gastown` role pack.

[workspace]
# NOTE: the workspace name lives in .gc/site.toml (workspace_name); gc v2
# treats workspace identity fields in city.toml as deprecated.
provider = "claude"
global_fragments = ["command-glossary", "operational-awareness"]

# Provider catalog. gc requires the workspace's provider to be declared here.
[providers.claude]
base = "builtin:claude"

# Per-rig pack imports — every registered rig auto-imports gastown's rig-scoped
# agents (witness, refinery, polecat) without per-rig editing.
[defaults.rig.imports.gastown]
source = "github.com/gastownhall/gascity.git//examples/gastown/packs/gastown"

[daemon]
patrol_interval = "30s"
max_restarts = 5
restart_window = "1h"
shutdown_timeout = "10s"
wisp_gc_interval = "5m"
wisp_ttl = "30m"
formula_v2 = true

[beads]
# Dolt-backed bead store via the `bd` binary, required by the gastown pack
# (which makes hundreds of `gc bd` calls). gc manages the Dolt SQL server itself
# (no separate process to babysit, no external-endpoint bootstrap dance).
provider = "bd"

[dolt]
# gc-managed Dolt SQL server. host = "0.0.0.0" + the published 3307 port makes the
# bead store reachable as a host/port by the whole compose project (city:3307)
# and from the host (127.0.0.1:3307). The database files live under the mounted
# /workspace and are NEVER pushed to a git remote — this store is local-only.
host = "0.0.0.0"
port = 3307

[orders]
max_timeout = "10m"

# Rigs. Filesystem path bindings live in .gc/site.toml (machine-local), written
# by the entrypoint. `prefix` is required so rig1/rig2 don't both auto-derive
# the colliding "ri" bead prefix.
[[rigs]]
name = "rig1"
prefix = "r1"

[[rigs]]
name = "rig2"
prefix = "r2"
