# Software Factory v4 prototype — environment for docker compose.
# Copy to .env and fill in your Claude subscription token.
#
#   cp .env.example .env
#   # then edit .env (see below)

# === Claude auth (subscription) =============================================
# If you have a Claude Pro/Max subscription (NOT a pay-as-you-go API key),
# generate a long-lived token ON YOUR LAPTOP with:
#
#   claude setup-token
#
# Paste the token here. The agents in the container authenticate with it.
CLAUDE_CODE_OAUTH_TOKEN=

# Only set this if you are using a pay-as-you-go Anthropic API key instead of a
# subscription. Leave empty when using CLAUDE_CODE_OAUTH_TOKEN above.
ANTHROPIC_API_KEY=

# === Rigs (the projects the city's agents work on) ==========================
# Leave the URLs empty for self-contained empty local rigs (recommended for a
# first run — zero external repos needed). Set them to any git URL to clone a
# real project into a rig instead.
RIG1_NAME=rig1
RIG2_NAME=rig2
RIG1_URL=
RIG2_URL=
RIG1_BRANCH=main
RIG2_BRANCH=main

# === Progress-tracker TUI build (operator instrument) =======================
# The TUI ("Gascity progress tracker") ships baked into the city image and runs
# as:  docker compose exec city sftui
#
# To have the prototype BUILD/extend the TUI via its own dogfood loop and push
# the result back out for review, point a rig at THIS repo and give the
# container a push token. Both stay in .env only (gitignored):
#
#   RIG1_URL=https://github.com/lago-morph/software-factory-prototype.git
#   RIG_PUSH_TOKEN=ghp_xxx      # GitHub token with push scope
#
# Then drive the chunk-1 build bead (see tui/README.md). Leave these empty for
# the normal self-contained demo (no TUI build rig, no credentials).
RIG_PUSH_TOKEN=
RIG_COMMIT_NAME=
RIG_COMMIT_EMAIL=
