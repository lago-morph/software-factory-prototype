# Software Factory v4 prototype — environment for docker compose.
# Copy to .env and fill in your Claude subscription token.
#
#   cp .env.example .env
#   # then edit .env (see below)

# === Claude auth (subscription) =============================================
# If you have a Claude Pro/Max subscription (NOT a pay-as-you-go API key),
# generate a long-lived token ON YOUR LAPTOP with:
#
#   claude setup-token
#
# Paste the token here. The agents in the container authenticate with it.
CLAUDE_CODE_OAUTH_TOKEN=

# Only set this if you are using a pay-as-you-go Anthropic API key instead of a
# subscription. Leave empty when using CLAUDE_CODE_OAUTH_TOKEN above.
ANTHROPIC_API_KEY=

# === Rigs (the projects the city's agents work on) ==========================
# Leave the URLs empty for self-contained empty local rigs (recommended for a
# first run — zero external repos needed). Set them to any git URL to clone a
# real project into a rig instead.
RIG1_NAME=rig1
RIG2_NAME=rig2
RIG1_URL=
RIG2_URL=
RIG1_BRANCH=main
RIG2_BRANCH=main
